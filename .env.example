# Convex Configuration
CONVEX_DEPLOYMENT=your-deployment-id
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-id.convex.cloud

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=viralai-videos
AWS_S3_PUBLIC_URL=https://viralai-videos.s3.amazonaws.com

# CloudFront Configuration
CLOUDFRONT_DOMAIN=your-distribution-domain.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id

# AI Video Generation APIs
VEO_API_KEY=your-veo-api-key
VEO_API_URL=https://api.veo.com
RUNWAY_API_KEY=your-runway-api-key
RUNWAY_API_URL=https://api.runwayml.com
LUMA_API_KEY=your-luma-api-key
LUMA_API_URL=https://api.lumalabs.ai

# Social Media APIs for Trend Scraping
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=ViralAI/1.0

# FFmpeg Configuration (optional - defaults to system PATH)
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# File Upload Configuration
MAX_FILE_SIZE=500000000
ALLOWED_VIDEO_FORMATS=mp4,mov,avi,mkv,webm
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp

# Feature Flags
ENABLE_VIDEO_TRANSCODING=true
ENABLE_THUMBNAIL_GENERATION=true
ENABLE_CDN_DELIVERY=true
ENABLE_CLEANUP_JOBS=true

# Development Configuration
DEBUG=false
VERBOSE_LOGGING=false